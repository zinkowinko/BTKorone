{
	"manifest_version": 2,

	"name": "BTKorone - Making Korone Better",
	"short_name": "BTKorone",
	"description": "Enhance your Korone experience! Extension created by zinko, visit https://btkor.one for more info.",
	"version": "2.13.1",
	"author": "AntiBoomz",

	"browser_action": {
		"default_title": "Open BTKorone Settings"
	},

	"icons": {
		"128": "res/icon_128.png"
	},

	"applications": {
		"gecko": {
			"id": "btKorone@btkor.one"
		}
	},

	"background": {
		"scripts": [
			"js/common.js",
			"js/background/blogfeed.js",
			"js/background/groupshout.js",
			"js/background/contextmenu.js",
			"js/background/browseraction.js",
			"js/background/fetch.js"
		]
	},
	"host_permissions": [
		"https://koromons.xyz*"
	],
	"permissions": [
		"*://*.pekora.zip/",
		"*://*.pekora.zip/",
		"clipboardWrite",
		"contextMenus",
		"notifications",
		"storage"
	],

	"web_accessible_resources": [
		"sourceviewer.html",
		"js/inject.js",
		"lib/*",
		"css/*",
		"res/*"
	],

	"content_scripts": [
		{
			"matches": [ "*://www.pekora.zip/*", "*://web.pekora.zip/*" ],
			"js": [
				"js/common.js",
				"js/utility.js",
				"js/inject.js",
				"js/main.js",

				"js/feat/fastSearch.js",
				"js/feat/navigation.js",

				"js/rbx/Parser.js",
				"js/rbx/AssetCache.js",

				"js/pages/common_pages.js",
				"js/pages/avatar.js",
				"js/pages/catalog.js",
				"js/pages/develop.js",
				"js/pages/friends.js",
				"js/pages/games.js",
				"js/pages/gamedetails.js",
				"js/pages/tixexchange.js",
				"js/pages/robuxexchange.js",
				"js/pages/groups.js",
				"js/pages/home.js",
				"js/pages/inventory.js",
				"js/pages/itemdetails.js",
				"js/pages/messages.js",
				"js/pages/money.js",
				"js/pages/placeconfig.js",
				"js/pages/profile.js",

				"js/final.js"
			],
			"run_at": "document_start",
			"all_frames": true
		}
	]
}